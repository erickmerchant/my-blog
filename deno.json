{
  "unstable": ["temporal", "raw-imports"],
  "tasks": {
    "new:post": "deno run -A cli/new-post.ts",
    "dev": "deno serve -A --port=4000 --watch-hmr flint.ts --dev",
    "build": "deno run -A flint.ts --build",
    "stage": {
      "command": "deno serve -A --port=4000 --parallel dist/serve.ts",
      "dependencies": ["build"]
    }
  },
  "imports": {
    "@feed/feed": "jsr:@feed/feed@^1.3.0",
    "@flint/framework": "jsr:@flint/framework@^0.34.3",
    "@handcraft/lib": "jsr:@handcraft/lib@^4.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/text": "jsr:@std/text@^1.0.18",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "markdown-it": "npm:markdown-it@^14.2.0",
    "markdown-it-highlightjs": "npm:markdown-it-highlightjs@^4.3.0",
    "parse5": "npm:parse5@^8.0.1"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "deno.window",
      "deno.unstable",
      "dom",
      "dom.iterable",
      "es2023"
    ]
  }
}
